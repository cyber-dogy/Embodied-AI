{
  "run_name": "unplug_charger_mdit_lane_b_faithful_fm_v1",
  "task_name": "unplug_charger",
  "obs_mode": "rgb",
  "encoder_name": "clip_rgb_text_faithful",
  "backbone_name": "dit",
  "research_lane": "lane_b_faithful",
  "train_data_path": "data/unplug_charger/train",
  "valid_data_path": "data/unplug_charger/valid",
  "seed": 1234,
  "device": "cuda",
  "resume_from_latest": false,

  "n_obs_steps": 3,
  "n_pred_steps": 32,
  "subs_factor": 3,
  "n_points": 2048,
  "obs_features_dim": 256,
  "y_dim": 10,

  "camera_names": ["right_shoulder", "left_shoulder", "overhead", "front", "wrist"],
  "text_source": "task_template",
  "task_text_override": null,

  "vision_backbone_name": "vit_base_patch16_clip_224.openai",
  "vision_pretrained": true,
  "vision_image_size": [224, 224],
  "vision_train_mode": "last_block",
  "vision_num_unfreeze_blocks": 1,
  "text_model_name": "openai/clip-vit-base-patch16",
  "text_projection_dim": 256,
  "token_fusion_mode": "3_token",

  "hidden_dim": 512,
  "time_dim": 256,
  "num_blocks": 6,
  "nhead": 8,
  "dim_feedforward": 2048,
  "dropout": 0.1,
  "activation": "gelu",
  "debug_finiteness": true,
  "final_layer_zero_init": false,
  "decoder_condition_mode": "mean_pool",

  "batch_size": 32,
  "grad_accum_steps": 4,
  "num_workers": 4,
  "train_epochs": 100,
  "train_use_amp": false,
  "train_amp_dtype": "bfloat16",
  "grad_clip_norm": 1.0,
  "empty_cuda_cache": true,

  "auto_batch_fallback": true,
  "batch_fallback_tiers": [[32, 4], [16, 8], [8, 16]],

  "learning_rate": 0.0001,
  "betas": [0.9, 0.95],
  "eps": 1e-8,
  "transformer_weight_decay": 0.001,
  "obs_encoder_weight_decay": 0.000001,
  "lr_scheduler_name": "cosine",
  "lr_warmup_steps": 1000,

  "ema_enable": true,
  "ema_decay": 0.9993,

  "val_every_epochs": 1,
  "success_selection_every_epochs": 0,
  "checkpoint_every_epochs": 50,
  "sample_every_epochs": 5,
  "success_selection_episodes": 0,
  "success_max_steps": 200,
  "standard_eval_episodes": 0,
  "eval_step_heartbeat_every": 50,

  "smooth_actions": false,
  "command_mode": "first",
  "horizon_index": 0,
  "average_first_n": 1,
  "position_alpha": 0.35,
  "rotation_alpha": 0.25,
  "max_position_step": 0.03,
  "gripper_open_threshold": 0.6,
  "gripper_close_threshold": 0.4,

  "norm_pcd_center": [0.4, 0.0, 1.4],
  "loss_type": "l2",
  "fm_num_k_infer": 10,
  "fm_time_conditioning": true,
  "fm_noise_type": "gaussian",
  "fm_noise_scale": 1.0,
  "fm_flow_schedule": "exp",
  "fm_exp_scale": 4.0,
  "fm_snr_sampler": "uniform",

  "wandb_enable": true,
  "wandb_project": "autodl-unplug-charger-mdit",
  "wandb_entity": "cyber-dogy",
  "wandb_mode": "online",
  "wandb_resume": false,

  "ckpt_root": "ckpt",
  "print_every": 50,
  "train_heartbeat_every_steps": 50
}
