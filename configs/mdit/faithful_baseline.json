{
  "run_name": "unplug_charger_mdit_faithful_v1",
  "task_name": "unplug_charger",
  "train_data_path": "data/unplug_charger/train",
  "valid_data_path": "data/unplug_charger/valid",
  "device": "cuda",
  "seed": 1234,
  "resume_from_latest": false,
  "n_obs_steps": 3,
  "horizon": 32,
  "n_action_steps": 16,
  "robot_state_dim": 10,
  "action_dim": 10,
  "camera_names": ["front", "wrist", "overhead"],
  "task_text_mode": "template",
  "task_text_override": null,
  "observation_encoder": {
    "vision": {
      "backbone": "vit_base_patch16_clip_224.openai",
      "use_separate_encoder_per_camera": false,
      "lr_multiplier": 0.1,
      "resize_shape": [240, 240],
      "crop_shape": [224, 224],
      "crop_is_random": true,
      "train_mode": "frozen"
    },
    "text": {
      "model": "openai/clip-vit-base-patch16"
    }
  },
  "transformer": {
    "hidden_dim": 512,
    "num_layers": 6,
    "num_heads": 8,
    "dropout": 0.1,
    "use_positional_encoding": true,
    "diffusion_step_embed_dim": 256,
    "use_rope": false,
    "rope_base": 10000.0
  },
  "objective": {
    "objective_name": "flow_matching",
    "sigma_min": 0.001,
    "num_integration_steps": 25,
    "integration_method": "euler",
    "timestep_sampling": {
      "strategy_name": "beta",
      "s": 0.999,
      "alpha": 1.5,
      "beta": 1.0
    }
  },
  "normalization_mode": "MIN_MAX",
  "batch_size": 8,
  "grad_accum_steps": 4,
  "num_workers": 4,
  "train_epochs": 500,
  "grad_clip_norm": 1.0,
  "use_amp": true,
  "ema_enable": true,
  "ema_decay": 0.9993,
  "checkpoint_every_epochs": 100,
  "val_every_epochs": 1,
  "print_every": 50,
  "lr_scheduler_name": "cosine",
  "lr_warmup_steps": 500,
  "optimizer_lr": 2.0e-5,
  "optimizer_betas": [0.9, 0.999],
  "optimizer_eps": 1.0e-8,
  "optimizer_weight_decay": 1.0e-4,
  "success_max_steps": 200,
  "eval_step_heartbeat_every": 50
}
