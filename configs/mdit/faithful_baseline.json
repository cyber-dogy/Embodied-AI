{
  "run_name": "unplug_charger_mdit_faithful_baseline",
  "task_name": "unplug_charger",
  "train_data_path": "data/unplug_charger/train",
  "valid_data_path": "data/unplug_charger/valid",
  "device": "cuda",
  "seed": 1234,
  "resume_from_latest": false,
  "n_obs_steps": 2,
  "horizon": 100,
  "n_action_steps": 24,
  "robot_state_dim": 10,
  "action_dim": 10,
  "camera_names": ["right_shoulder", "left_shoulder", "overhead", "front", "wrist"],
  "task_text_mode": "template",
  "observation_encoder": {
    "vision": {
      "backbone": "vit_base_patch16_clip_224.openai",
      "use_separate_encoder_per_camera": true,
      "lr_multiplier": 0.1,
      "resize_shape": [224, 224],
      "crop_shape": [224, 224],
      "crop_is_random": true,
      "train_mode": "last_block",
      "num_unfreeze_blocks": 1
    },
    "text": {
      "model": "openai/clip-vit-base-patch16"
    }
  },
  "transformer": {
    "hidden_dim": 512,
    "num_layers": 6,
    "num_heads": 8,
    "dropout": 0.1,
    "use_positional_encoding": true,
    "diffusion_step_embed_dim": 256,
    "use_rope": false,
    "rope_base": 10000.0
  },
  "objective": {
    "objective_name": "flow_matching",
    "sigma_min": 0.0,
    "num_integration_steps": 50,
    "integration_method": "euler",
    "timestep_sampling": {
      "strategy_name": "beta",
      "s": 0.999,
      "alpha": 1.5,
      "beta": 1.0
    },
    "loss_weights": {
      "xyz": 1.0,
      "rot6d": 1.0,
      "grip": 1.0
    }
  },
  "normalization_mode": "MIN_MAX",
  "batch_size": 8,
  "grad_accum_steps": 4,
  "num_workers": 8,
  "train_epochs": 500,
  "grad_clip_norm": 1.0,
  "use_amp": true,
  "checkpoint_every_epochs": 20,
  "val_every_epochs": 1,
  "print_every": 50,
  "save_latest_ckpt": true,
  "save_best_valid_ckpt": true,
  "ema_enable": false,
  "checkpoint_payload_mode": "full",
  "enable_success_rate_eval": true,
  "offline_eval_ckpt_every_epochs": 0,
  "offline_eval_ckpt_payload_mode": "lightweight",
  "audit_include_special_ckpts": true,
  "delete_screening_ckpts_after_audit": false,
  "delete_periodic_ckpts_after_success_eval": false,
  "lr_scheduler_name": "cosine",
  "lr_warmup_steps": 500,
  "optimizer_lr": 2e-5,
  "optimizer_betas": [0.95, 0.999],
  "optimizer_eps": 1e-08,
  "optimizer_weight_decay": 0.0,
  "wandb_enable": true,
  "wandb_project": "autodl-unplug-charger-mdit",
  "wandb_mode": "online",
  "wandb_resume": true,
  "success_selection_every_epochs": 20,
  "success_selection_episodes": 20,
  "success_max_steps": 200,
  "success_eval_timeout_sec": 7200,
  "standard_eval_episodes": 0,
  "eval_step_heartbeat_every": 50,
  "rlbench_disable_task_validation": false,
  "smooth_actions": false,
  "command_mode": "first",
  "horizon_index": 0,
  "average_first_n": 1,
  "position_alpha": 0.35,
  "rotation_alpha": 0.25,
  "max_position_step": 0.03,
  "gripper_open_threshold": 0.6,
  "gripper_close_threshold": 0.4
}
