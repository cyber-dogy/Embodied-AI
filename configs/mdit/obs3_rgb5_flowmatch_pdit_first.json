{
  "extends": "mdit/faithful_baseline.json",
  "run_name": "unplug_charger_mdit_rgb5_flowmatch_pdit_first_v1",
  "n_obs_steps": 3,
  "horizon": 32,
  "n_action_steps": 1,
  "camera_names": ["right_shoulder", "left_shoulder", "overhead", "front", "wrist"],
  "batch_size": 96,
  "grad_accum_steps": 1,
  "num_workers": 8,
  "use_amp": true,
  "save_latest_ckpt": true,
  "save_best_valid_ckpt": true,
  "checkpoint_payload_mode": "full",
  "wandb_enable": true,
  "wandb_mode": "online",
  "wandb_resume": true,
  "observation_encoder": {
    "vision": {
      "backbone": "vit_base_patch16_clip_224.openai",
      "use_separate_encoder_per_camera": false,
      "lr_multiplier": 0.1,
      "resize_shape": [224, 224],
      "crop_shape": [224, 224],
      "crop_is_random": true,
      "train_mode": "all"
    },
    "text": {
      "model": "openai/clip-vit-base-patch16"
    }
  },
  "transformer": {
    "hidden_dim": 512,
    "num_layers": 6,
    "num_heads": 8,
    "dropout": 0.1,
    "use_positional_encoding": true,
    "diffusion_step_embed_dim": 256,
    "use_rope": false,
    "rope_base": 10000.0
  },
  "objective": {
    "objective_name": "flow_matching",
    "sigma_min": 0.0,
    "num_integration_steps": 50,
    "integration_method": "euler",
    "timestep_sampling": {
      "strategy_name": "beta",
      "s": 0.999,
      "alpha": 1.5,
      "beta": 1.0
    }
  }
}
