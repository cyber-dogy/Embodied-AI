{
  "run_name": "unplug_charger_lelan_v1",
  "task_name": "unplug_charger",
  "train_data_path": "data/unplug_charger/train",
  "valid_data_path": "data/unplug_charger/valid",
  "device": "cuda",
  "seed": 1234,
  "resume_from_latest": false,
  "n_obs_steps": 3,
  "horizon": 32,
  "n_action_steps": 16,
  "robot_state_dim": 10,
  "action_dim": 10,
  "camera_names": ["front", "wrist", "overhead", "left_shoulder", "right_shoulder"],
  "task_text_mode": "template",
  "task_text_override": null,
  "film": {
    "num_res_blocks": 8,
    "num_channels": 128,
    "use_coord_conv": true
  },
  "history_encoder": {
    "backbone": "efficientnet-b0",
    "encoding_dim": 512,
    "features_per_group": 16
  },
  "text_encoder": {
    "model": "openai/clip-vit-base-patch16",
    "freeze": true
  },
  "fusion_transformer": {
    "hidden_dim": 512,
    "num_heads": 4,
    "num_layers": 2,
    "ff_dim_factor": 4,
    "dropout": 0.1
  },
  "transformer": {
    "hidden_dim": 512,
    "num_layers": 6,
    "num_heads": 8,
    "dropout": 0.1,
    "use_positional_encoding": true,
    "diffusion_step_embed_dim": 256,
    "use_rope": false,
    "rope_base": 10000.0
  },
  "objective": {
    "objective_name": "flow_matching",
    "sigma_min": 0.0,
    "num_integration_steps": 50,
    "integration_method": "euler",
    "timestep_sampling": {
      "strategy_name": "beta",
      "s": 0.999,
      "alpha": 1.5,
      "beta": 1.0
    }
  },
  "normalization_mode": "MIN_MAX",
  "batch_size": 8,
  "grad_accum_steps": 4,
  "num_workers": 4,
  "train_epochs": 500,
  "grad_clip_norm": 1.0,
  "use_amp": true,
  "checkpoint_every_epochs": 100,
  "val_every_epochs": 1,
  "print_every": 50,
  "lr_scheduler_name": "cosine",
  "lr_warmup_steps": 500,
  "optimizer_lr": 2.0e-5,
  "optimizer_betas": [0.95, 0.999],
  "optimizer_eps": 1.0e-8,
  "optimizer_weight_decay": 0.0,
  "use_ema": true,
  "ema_decay": 0.999,
  "wandb_enable": false,
  "wandb_project": "autodl-unplug-charger-lelan",
  "wandb_mode": "disabled",
  "success_max_steps": 200,
  "eval_step_heartbeat_every": 50
}
