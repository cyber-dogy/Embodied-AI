{
  "run_name": "unplug_charger_lelan_v2",
  "task_name": "unplug_charger",
  "obs_mode": "rgb",
  "encoder_name": "clip_rgb_history_token",
  "backbone_name": "dit",
  "fm_variant": "standard",
  "normalization_profile": "legacy",
  "research_lane": "lelan_history_mainline",
  "train_data_path": "data/unplug_charger/train",
  "valid_data_path": "data/unplug_charger/valid",
  "device": "cuda",
  "seed": 1234,
  "resume_from_latest": false,

  "n_obs_steps": 3,
  "n_pred_steps": 32,
  "n_action_steps": 8,
  "subs_factor": 3,
  "n_points": 2048,
  "use_pc_color": false,
  "obs_features_dim": 256,
  "y_dim": 10,

  "camera_names": ["right_shoulder", "left_shoulder", "overhead", "front", "wrist"],
  "text_source": "task_template",
  "task_text_override": null,

  "vision_backbone_name": "vit_base_patch16_clip_224.openai",
  "vision_pretrained": true,
  "vision_image_size": [224, 224],
  "vision_train_mode": "last_block",
  "vision_num_unfreeze_blocks": 1,
  "text_model_name": "openai/clip-vit-base-patch16",
  "text_projection_dim": 256,
  "token_fusion_mode": "3_token",
  "vision_lr_multiplier": 1.0,
  "activation_checkpointing": false,
  "history_encoder": {
    "backbone": "efficientnet-b0",
    "pretrained": false,
    "features_per_group": 16
  },

  "hidden_dim": 512,
  "time_dim": 256,
  "num_blocks": 6,
  "nhead": 8,
  "dim_feedforward": 2048,
  "dropout": 0.1,
  "activation": "gelu",
  "debug_finiteness": true,
  "final_layer_zero_init": false,
  "decoder_condition_mode": "mean_pool",
  "use_rope": false,
  "rope_base": 10000.0,
  "use_positional_encoding": true,

  "batch_size": 8,
  "grad_accum_steps": 4,
  "num_workers": 4,
  "train_epochs": 500,
  "train_use_amp": true,
  "train_amp_dtype": "bfloat16",
  "grad_clip_norm": 1.0,
  "empty_cuda_cache": false,

  "learning_rate": 0.00002,
  "betas": [0.95, 0.999],
  "eps": 1e-8,
  "transformer_weight_decay": 0.0,
  "obs_encoder_weight_decay": 0.0,
  "lr_scheduler_name": "cosine",
  "lr_warmup_steps": 500,

  "ema_enable": true,
  "ema_decay": 0.999,

  "fm_num_k_infer": 10,
  "fm_time_conditioning": true,
  "fm_noise_type": "gaussian",
  "fm_noise_scale": 1.0,
  "fm_flow_schedule": "exp",
  "fm_exp_scale": 4.0,
  "fm_snr_sampler": "uniform",
  "fm_sigma_min": 0.0,
  "fm_num_integration_steps": 50,
  "fm_integration_method": "euler",
  "fm_timestep_sampling_strategy": "beta",
  "fm_timestep_beta_s": 0.999,
  "fm_timestep_beta_alpha": 1.5,
  "fm_timestep_beta_beta": 1.0,
  "fm_loss_weights": {
    "xyz": 1.0,
    "rot6d": 1.0,
    "grip": 1.0
  },

  "wandb_enable": false,
  "wandb_project": "autodl-unplug-charger-lelan",
  "wandb_mode": "disabled",
  "wandb_resume": false,

  "checkpoint_every_epochs": 100,
  "val_every_epochs": 1,
  "print_every": 50,
  "train_heartbeat_every_steps": 50,
  "save_latest_ckpt": true,
  "save_best_valid_ckpt": true,
  "checkpoint_payload_mode": "full",
  "enable_success_rate_eval": true,
  "offline_eval_ckpt_every_epochs": 0,
  "offline_eval_ckpt_payload_mode": "lightweight",
  "audit_include_special_ckpts": true,
  "delete_screening_ckpts_after_audit": false,
  "delete_periodic_ckpts_after_success_eval": false,

  "success_selection_every_epochs": 0,
  "success_selection_episodes": 0,
  "success_max_steps": 200,
  "standard_eval_episodes": 0,
  "eval_step_heartbeat_every": 50,
  "smooth_actions": false,
  "command_mode": "first",
  "horizon_index": 0,
  "average_first_n": 1,
  "position_alpha": 0.35,
  "rotation_alpha": 0.25,
  "max_position_step": 0.03,
  "gripper_open_threshold": 0.6,
  "gripper_close_threshold": 0.4
}
