{
  "extends": "lelan/baseline.json",
  "run_name": "unplug_charger_lelan_obs3_rgb5_a8_gate100",

  "n_obs_steps": 3,
  "n_pred_steps": 32,
  "n_action_steps": 8,
  "camera_names": ["right_shoulder", "left_shoulder", "overhead", "front", "wrist"],

  "batch_size": 8,
  "grad_accum_steps": 1,
  "num_workers": 8,
  "train_use_amp": true,
  "save_latest_ckpt": true,
  "save_best_valid_ckpt": true,
  "checkpoint_payload_mode": "full",

  "enable_success_rate_eval": true,
  "success_selection_every_epochs": 100,
  "success_selection_episodes": 20,

  "smooth_actions": true,
  "command_mode": "first",
  "position_alpha": 0.35,
  "rotation_alpha": 0.25,
  "max_position_step": 0.03,
  "gripper_open_threshold": 0.6,
  "gripper_close_threshold": 0.4,

  "wandb_enable": true,
  "wandb_mode": "online",
  "wandb_resume": true,

  "fm_sigma_min": 0.001,
  "fm_num_integration_steps": 25,
  "fm_integration_method": "euler",
  "fm_timestep_sampling_strategy": "beta",
  "fm_timestep_beta_s": 0.999,
  "fm_timestep_beta_alpha": 1.5,
  "fm_timestep_beta_beta": 1.0
}
