{
  "seed": 1234,
  "device": "cuda",
  "resume_from_latest": false,
  "batch_size": 32,
  "grad_accum_steps": 2,
  "num_workers": 4,
  "train_epochs": 500,
  "train_use_amp": false,
  "train_amp_dtype": "bfloat16",
  "grad_clip_norm": 1.0,
  "empty_cuda_cache": true,
  "learning_rate": 0.0001,
  "betas": [0.9, 0.95],
  "eps": 1e-08,
  "transformer_weight_decay": 0.001,
  "obs_encoder_weight_decay": 1e-06,
  "lr_scheduler_name": "cosine",
  "lr_warmup_steps": 1000,
  "ema_enable": true,
  "ema_decay": 0.9993,
  "val_every_epochs": 1,
  "checkpoint_every_epochs": 100,
  "sample_every_epochs": 5,
  "print_every": 50,
  "wandb_enable": false,
  "wandb_mode": "disabled",
  "wandb_resume": false
}
